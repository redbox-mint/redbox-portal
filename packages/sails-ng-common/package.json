{
  "name": "@researchdatabox/sails-ng-common",
  "version": "0.2.1",
  "description": "Common models shared between Sails API endpoints and client-side Angular code",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "./dist/src"
  ],
  "scripts": {
    "test": "nyc --reporter=text mocha --exit --config test/unit/.mocharc.js dist/test/unit",
    "pretest": "npm run test:compile && mkdir -p support/junit",
    "test:clean": "rm -rf support/junit || true",
    "compile": "tsc -p tsconfig.prod.json",
    "compile:clean": "rm -rf dist/",
    "test:compile": "tsc -p tsconfig.test.json",
    "pretest:compile": "npm run compile:clean"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/redbox-mint/redbox-portal.git"
  },
  "keywords": [
    "redbox",
    "research",
    "research",
    "data",
    "management",
    "planning"
  ],
  "author": "QCIF Engineering",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/redbox-mint/redbox-portal/issues"
  },
  "homepage": "https://github.com/redbox-mint/redbox-portal/packages/sails-ng-common",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/chai": "5.2.3",
    "@types/lodash": "4.17.24",
    "@types/lodash-es": "4.17.12",
    "@types/luxon": "3.7.1",
    "@types/mocha": "10.0.10",
    "@types/node": "24.12.0",
    "chai": "6.2.2",
    "jsonata": "2.1.0",
    "mocha": "11.7.5",
    "mocha-junit-reporter": "2.2.1",
    "nyc": "18.0.0",
    "serialize-javascript": "7.0.5",
    "typescript": "6.0.2"
  },
  "nyc": {
    "check-coverage": true,
    "all": true,
    "lines": 45,
    "statements": 45,
    "functions": 45,
    "branches": 45,
    "include": [
      "**/src/handlebars-helpers.*",
      "**/src/config/names/**/*.*",
      "**/src/validation/**/*.*"
    ],
    "reporter": [
      "lcov",
      "text",
      "text-summary"
    ]
  },
  "dependencies": {
    "@jsonjoy.com/json-pointer": "18.5.0",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "luxon": "3.7.2",
    "marked": "17.0.5",
    "ts-json-schema-generator": "2.9.0"
  },
  "overrides": {
    "mocha": {
      "serialize-javascript": "7.0.5"
    }
  },
  "peerDependencies": {
    "jsonata": "2.1.0"
  }
}
