{
  "extends": "../redbox-dev-tools/config/tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "ignoreDeprecations": "5.0",
    "declaration": true,
    "strict": false,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "exclude": [
    "node_modules/**",
    "dist/**",
    "test/**/*.ts"
  ],
  "include": [
    "src/**/*.ts"
  ]
}
