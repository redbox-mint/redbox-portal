{
  "name": "@researchdatabox/redbox-dev-tools",
  "version": "4.5.1",
  "description": "ReDBox customisation dev tools - shared configuration, generators, and migration tooling",
  "type": "commonjs",
  "main": "index.js",
  "bin": {
    "redbox-dev-tools": "./bin/cli.js",
    "redbox-hook-mocha": "./bin/run-hook-mocha.js",
    "redbox-hook-tsc": "./bin/run-hook-tsc.js"
  },
  "files": [
    "bin/",
    "dist/",
    "config/",
    "templates/",
    "skills/",
    "index.js",
    "runtime-resolver.js",
    "runtime-resolver.d.ts",
    "testing.js",
    "testing.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "TS_NODE_PROJECT=test/tsconfig.json node -r ./node_modules/ts-node/register ./node_modules/mocha/bin/mocha.js --config .mocharc.js --exit \"test/**/*.test.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redbox-mint/redbox-portal.git#v4.5.1"
  },
  "keywords": [
    "Kit",
    "Dev",
    "Hook",
    "ReDBox",
    "TypeScript"
  ],
  "author": "Alejandro Bulgaris",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/redbox-mint/redbox-portal/issues"
  },
  "homepage": "https://github.com/redbox-mint/redbox-portal/tree/v4.5.1#readme",
  "dependencies": {
    "@researchdatabox/redbox-core": "file:../redbox-core",
    "@researchdatabox/sails-ng-common": "file:../sails-ng-common",
    "@tsconfig/node24": "^24.0.1",
    "@types/chai": "^4.3.11",
    "@types/lodash": "^4.17.20",
    "@types/mocha": "^10.0.6",
    "@types/node": "^24.10.0",
    "axios": "^1.11.0",
    "chai": "^4.3.10",
    "commander": "^14.0.0",
    "handlebars": "^4.7.8",
    "lodash": "^4.17.21",
    "mocha": "^10.2.0",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "ts-morph": "^21.0.1",
    "typescript": "^5.8.3",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/sinon": "^17.0.3",
    "sinon": "^17.0.1"
  },
  "peerDependenciesMeta": {
    "@researchdatabox/redbox-core": {
      "optional": false
    }
  },
  "overrides": {
    "mocha": {
      "serialize-javascript": "7.0.5"
    }
  }
}
