{
  "name": "@researchdatabox/sails-hook-redbox-storage-mongo",
  "version": "1.5.3",
  "description": "A MongoDB storage plugin for ReDBox.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sails": {
    "isHook": true,
    "hasModels": true,
    "hasServices": true,
    "hasConfig": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/redbox-mint/sails-hook-redbox-storage-mongo.git"
  },
  "scripts": {
    "compile": "npm run build",
    "build": "tsc -p tsconfig.json",
    "test": "TS_NODE_PROJECT=test/tsconfig.json mocha --require ts-node/register --require test/setup.ts \"test/**/*.test.ts\"",
    "test:coverage": "TS_NODE_PROJECT=test/tsconfig.json nyc --no-clean --report-dir ./coverage/storage-mongo --reporter=lcov --reporter=text --exclude-after-remap=false mocha --require ts-node/register --require test/setup.ts \"test/**/*.test.ts\"",
    "test:compile": "tsc -p test/tsconfig.json",
    "lint": "cd ../.. && oxlint packages/sails-hook-redbox-storage-mongo/src packages/sails-hook-redbox-storage-mongo/test",
    "lint:fix": "cd ../.. && oxlint packages/sails-hook-redbox-storage-mongo/src packages/sails-hook-redbox-storage-mongo/test --fix",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "keywords": [
    "sails",
    "hook",
    "redbox",
    "redbox research",
    "redbox storage",
    "redbox mongodb"
  ],
  "author": "QCIF Engineering dev@redboxresearchdata.com.au",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/chai": "5.2.3",
    "@types/lodash": "4.17.24",
    "@types/mocha": "10.0.10",
    "@tsconfig/node24": "24.0.4",
    "@types/sinon": "17.0.3",
    "@types/node": "24.12.0",
    "chai": "6.2.2",
    "fs": "0.0.1-security",
    "luxon": "3.7.2",
    "mocha": "11.7.5",
    "mocha-junit-reporter": "2.2.1",
    "mongodb": "7.1.1",
    "nyc": "17.1.0",
    "sails": "1.5.17",
    "sinon": "17.0.1",
    "serialize-javascript": "7.0.5",
    "stream": "0.0.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.2",
    "util": "0.12.5"
  },
  "dependencies": {
    "@researchdatabox/redbox-core": "file:../redbox-core",
    "json2csv": "5.0.7",
    "lodash": "4.17.23",
    "reflect-metadata": "0.2.2",
    "uuid": "13.0.0"
  },
  "peerDependencies": {
    "luxon": "3.7.2",
    "rxjs": "7.8.2"
  },
  "overrides": {
    "on-headers": "1.1.0",
    "serialize-javascript": "7.0.5",
    "compression": {
      "on-headers": "1.1.0"
    },
    "express-session": {
      "on-headers": "1.1.0"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "nyc": {
    "all": true,
    "include": [
      "src/**/*.ts"
    ],
    "reporter": [
      "lcov",
      "text"
    ]
  }
}
