meta {
  name: Save S3 attachment on Data Record
  type: http
  seq: 5
}

put {
  url: {{host}}/default/rdmp/recordmeta/{{s3AttachmentRecordOid}}
  body: json
  auth: none
}

headers {
  Pragma: no-cache
  Origin: {{host}}
  X-CSRF-Token:
  X-Source: jsclient
  Content-Type: application/json;charset=UTF-8
  Accept: application/json, text/plain, */*
  Cache-Control: no-cache
  Referer: {{host}}/default/rdmp/record/edit/{{s3AttachmentRecordOid}}
  Connection: keep-alive
}

