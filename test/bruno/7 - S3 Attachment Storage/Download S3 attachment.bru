meta {
  name: Download S3 attachment
  type: http
  seq: 6
}

get {
  url: http:{{s3AttachmentLocation}}
  body: none
  auth: none
}

script:pre-request {
  const bruHelper = require("./bruno-helpers.js");
  bruHelper.setCookies({bru, req});
}

tests {
  test("Status code is 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("Downloaded attachment has content", function () {
    const body = res.getBody();
    expect(body).to.not.equal(null);
    expect(String(body).length).to.be.greaterThan(0);
  });
}
