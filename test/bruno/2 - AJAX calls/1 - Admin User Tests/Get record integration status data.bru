meta {
  name: Get record integration status data
  type: http
  seq: 58
}

get {
  url: {{host}}/default/rdmp/record/integrationStatus/{{dmpOid}}?integrationName=doi,figshare
  body: none
  auth: none
}

headers {
  Pragma: no-cache
  Accept-Encoding: gzip, deflate, br
  X-CSRF-Token:
  Accept-Language: en-US,en;q=0.9,en-AU;q=0.8,it;q=0.5
  User-Agent: Mozilla/5.0 (Macintosh; Intel Mac OS X 10_14_1) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/70.0.3538.102 Safari/537.36
  Content-Type: application/json;charset=utf-8
  Accept: application/json, text/plain, */*
  Connection: keep-alive
  Referer: {{host}}/default/rdmp/record/viewAudit/{{dmpOid}}
  X-Source: jsclient
  Cache-Control: no-cache
}

script:pre-request {
  const bruHelper = require("./bruno-helpers.js");
  bruHelper.setCookies({bru, req});
}

tests {
  test("Status code is 200", function () {
      expect(res.getStatus()).to.equal(200);
  });

  test("Integration status response includes outcome for requested mapped integrations", function () {
      const jsonData = res.getBody();
      const data = jsonData.data ?? jsonData;
      expect(data.integrations).to.be.an("array");
      expect(data.integrations.length).to.be.at.least(1);
      data.integrations.forEach(function (item) {
        expect(item).to.have.property("integrationName");
        expect(item).to.have.property("status");
        expect(item).to.have.property("startedAt");
        expect(item).to.have.property("traceId");
        expect(item).to.not.have.property("errorDetail");
        expect(item).to.not.have.property("requestSummary");
        expect(item).to.not.have.property("responseSummary");
        expect(item).to.not.have.property("httpStatusCode");
        // Items for doi or figshare must have an outcome object with the contract shape
        if (item.integrationName === "doi" || item.integrationName === "figshare") {
          expect(item.outcome).to.be.an("object");
          expect(item.outcome).to.have.property("state");
          expect(item.outcome).to.have.property("severity");
          expect(item.outcome).to.have.property("labelKey");
          expect(item.outcome.state).to.be.a("string").that.is.not.empty;
          expect(item.outcome.severity).to.be.oneOf(["none","pending","in-progress","success","warning","error"]);
          expect(item.outcome.labelKey).to.be.a("string").that.is.not.empty;
        }
      });
  });
}
