meta {
  name: Get linked accounts for researcher user
  type: http
  seq: 56
}

get {
  url: {{host}}/default/rdmp/admin/users/{{researcherUserId}}/links
  body: none
  auth: none
}

headers {
  Pragma: no-cache
  Accept-Encoding: gzip, deflate, br
  X-CSRF-Token:
  Accept-Language: en-US,en;q=0.9,en-AU;q=0.8,it;q=0.7
  User-Agent: Mozilla/5.0 (Macintosh; Intel Mac OS X 10_14_1) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/70.0.3538.102 Safari/537.36
  Content-Type: application/json;charset=utf-8
  Accept: application/json, text/plain, */*
  Connection: keep-alive
  Referer: {{host}}/default/rdmp/admin/users
  X-Source: jsclient
  Cache-Control: no-cache
}

script:pre-request {
  const bruHelper = require("./bruno-helpers.js");
  bruHelper.setCookies({bru, req});
}

tests {
  test("Status code is 200", function () {
      expect(res.getStatus()).to.equal(200);
  });

  test("Linked account list returns the secondary researcher", function () {
      var jsonData = res.getBody();
      expect(jsonData.primary.id).to.eql(bru.getEnvVar("researcherUserId"));
      expect(jsonData.linkedAccounts.length).to.equal(1);
      expect(jsonData.linkedAccounts[0].id).to.eql(bru.getEnvVar("secondaryResearcherUserId"));
  });
}
