meta {
  name: Search Service Lookup
  type: http
  seq: 14
}

post {
  url: {{host}}/default/rdmp/service/vocab/integrationContributors
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
  X-ReDBox-Api-Version: 2.0
}

body:json {
  {
    "search": "smith",
    "start": 0,
    "rows": 10
  }
}

tests {
  test("Status code is 200", function () {
      expect(res.getStatus()).to.equal(200);
  });

  test("Service lookup returns wrapped data and meta", function () {
      const jsonData = res.getBody();
      expect(jsonData.data).to.be.an('array');
      expect(jsonData.meta.total).to.equal(2);
      expect(jsonData.data[0]).to.have.property('sourceType');
      expect(jsonData.data[0].sourceType).to.equal('service');
  });
}
