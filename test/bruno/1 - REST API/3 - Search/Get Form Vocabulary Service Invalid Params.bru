}

tests {
  test("Status code is 400", function () {
      expect(res.getStatus()).to.equal(400);
  });

  test("Error code is invalid-query-params", function () {
      const jsonData = res.getBody();
      const err = jsonData.errors[0];
      expect(err.code).to.equal('invalid-query-params');
  });
}
