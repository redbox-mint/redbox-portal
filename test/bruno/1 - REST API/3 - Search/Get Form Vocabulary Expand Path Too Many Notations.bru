meta {
  name: Get Form Vocabulary Expand Path Too Many Notations
  type: http
  seq: 14
}

get {
  url: {{host}}/default/rdmp/vocab/anzsrc-2020-for/expandPath?notation=0001,0002,0003,0004,0005,0006,0007,0008,0009,0010,0011,0012,0013,0014,0015,0016,0017,0018,0019,0020,0021,0022,0023,0024,0025,0026,0027,0028,0029,0030,0031,0032,0033,0034,0035,0036,0037,0038,0039,0040,0041,0042,0043,0044,0045,0046,0047,0048,0049,0050,0051,0052,0053,0054,0055,0056,0057,0058,0059,0060,0061,0062,0063,0064,0065,0066,0067,0068,0069,0070,0071,0072,0073,0074,0075,0076,0077,0078,0079,0080,0081,0082,0083,0084,0085,0086,0087,0088,0089,0090,0091,0092,0093,0094,0095,0096,0097,0098,0099,0100,0101
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  X-ReDBox-Api-Version: 2.0
}

tests {
  test("Status code is 400", function () {
      const status = res.getStatus();
      expect(status).to.equal(400);
  });

  test("Error code is too-many-notations", function () {
      expect(res.getStatus()).to.equal(400, "Expected status 400 before validating too-many-notations error payload");
      var jsonData = res.getBody();
      expect(jsonData && Array.isArray(jsonData.errors) && jsonData.errors.length > 0).to.equal(
        true,
        "Expected jsonData.errors to be a non-empty array before accessing first error"
      );
      var err = jsonData.errors[0];
      expect(err).to.have.property('code');
      expect(err.code).to.equal('too-many-notations');
  });
}
