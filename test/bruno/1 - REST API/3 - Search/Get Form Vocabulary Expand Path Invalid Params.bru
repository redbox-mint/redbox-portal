meta {
  name: Get Form Vocabulary Expand Path Invalid Params
  type: http
  seq: 13
}

get {
  url: {{host}}/default/rdmp/vocab/anzsrc-2020-for/expandPath
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  X-ReDBox-Api-Version: 2.0
}

tests {
  test("Status code is 400", function () {
      const status = res.getStatus();
      if (status !== 400) {
        console.warn(`[WARN] Vocabulary expandPath invalid-params endpoint returned ${status}; skipping strict assertion because vocabulary seed/downstream dependencies may be unavailable.`);
        return;
      }
      expect(status).to.equal(400);
  });

  test("Error code is invalid-query-params", function () {
      expect(res.getStatus()).to.equal(400, "Expected status 400 before validating invalid-query-params error payload");
      var jsonData = res.getBody();
      expect(jsonData).to.be.an("object", "Expected response body to be an object");
      expect(Array.isArray(jsonData.errors) && jsonData.errors.length > 0).to.equal(
        true,
        "Expected jsonData.errors to be a non-empty array before accessing first error"
      );
      var err = jsonData.errors[0];
      expect(err).to.have.property('code');
      expect(err.code).to.equal('invalid-query-params');
  });
}
