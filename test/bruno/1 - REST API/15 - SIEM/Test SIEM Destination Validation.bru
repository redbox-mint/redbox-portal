meta {
  name: Test SIEM Destination Validation
  type: http
  seq: 6
}

post {
  url: {{host}}/default/rdmp/api/siem/test
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  X-ReDBox-Api-Version: 2.0
  Content-Type: application/json
}

body:json {
  {}
}

tests {
  test("Status code is 400", function () {
    expect(res.getStatus()).to.equal(400);
  });

  test("Reports missing destination", function () {
    var jsonData = res.getBody();
    var bodyText = JSON.stringify(jsonData);
    expect(bodyText).to.contain("destination");
  });
}
