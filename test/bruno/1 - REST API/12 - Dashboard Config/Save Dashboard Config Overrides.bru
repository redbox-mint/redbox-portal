meta {
  name: Save Dashboard Config Overrides
  type: http
  seq: 4
}

put {
  url: {{host}}/default/rdmp/api/dashboard-config/overrides
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  X-ReDBox-Api-Version: 2.0
}

body:json {
  {
    "recordTypes": {
      "rdmp": {
        "steps": {
          "draft": {
            "rowConfig": [
              {
                "title": "Test Override",
                "variable": "metadata.title",
                "template": "{{title}}"
              }
            ]
          }
        }
      }
    },
    "views": {},
    "dashboardTypes": {}
  }
}

tests {
  test("Status code is 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("Has data property", function () {
    var jsonData = res.getBody();
    expect(jsonData).to.have.property("data");
  });
}
