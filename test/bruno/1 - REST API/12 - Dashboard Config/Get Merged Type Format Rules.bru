meta {
  name: Get Merged Type Format Rules
  type: http
  seq: 7
}

get {
  url: {{host}}/default/rdmp/api/dashboard-config/merged-type/standard
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  X-ReDBox-Api-Version: 2.0
}

tests {
  test("Status code is 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("Has data property", function () {
    var jsonData = res.getBody();
    expect(jsonData).to.have.property("data");
  });
}
