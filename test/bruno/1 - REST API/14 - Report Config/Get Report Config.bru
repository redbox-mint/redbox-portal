meta {
  name: Get Report Config
  type: http
  seq: 4
}

get {
  url: {{host}}/default/rdmp/api/report-config/bruno-report-config
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  X-ReDBox-Api-Version: 2.0
}

tests {
  test("Status code is 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("Returns created report config", function () {
    var jsonData = res.getBody();
    expect(jsonData).to.have.property("data");
    expect(jsonData.data).to.include({
      name: "bruno-report-config",
      title: "Bruno Report Config",
      readOnly: false
    });
    expect(jsonData.data.columns).to.be.an("array").with.length(2);
  });
}
